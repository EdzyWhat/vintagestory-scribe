{
	code: "scribelectern",
	class: "BlockScribeLectern",
	entityclass: "ScribeLectern",

	// Reuses the vanilla lectern shape (plain wood, not the "aged"/scavenged variant,
	// since this block is meant to be crafted rather than found). The shape's own
	// embedded textures are literal, resolvable paths, so no override is needed here.
	shape: { base: "game:block/clutter/bookshelves/lecturn-book-open" },

	creativeinventory: { "general": ["*"], "decorative": ["*"] },

	blockmaterial: "Wood",
	lightAbsorption: 0,
	sidesolid: { all: false },
	sideopaque: { all: false },
	faceCullMode: "NeverCull",
	replaceable: 500,
	resistance: 2,

	collisionbox: { x1: 0.1817, y1: 0, z1: 0.1875, x2: 0.8188, y2: 1.2563, z2: 0.8125 },
	selectionbox: { x1: 0.1817, y1: 0, z1: 0.1875, x2: 0.8188, y2: 1.2563, z2: 0.8125 },

	combustibleProps: {
		burnTemperature: 600,
		burnDuration: 10
	},

	sounds: {
		place: "block/planks",
		hit: "block/planks",
		break: "block/planks",
		walk: "walk/wood"
	},

	guiTransform: {
		rotation: { x: -22.6, y: 52 },
		origin: { x: 0.5, y: 0.6, z: 0.5 },
		scale: 1
	}
}
